# --- Transport ---
# stdio : default for direct agent integration (Copilot CLI, Claude Desktop)
# http  : streamable-http for remote/shared deployments
# sse   : legacy SSE (avoid for new clients)
BAILIFF_TRANSPORT=stdio
BAILIFF_HOST=0.0.0.0
BAILIFF_PORT=8100
BAILIFF_PATH=/mcp

# --- Upstream (any /v1/responses-compatible host with MCP tool support) ---
# Examples:
#   http://localhost:4000        LiteLLM proxy on the same host
#   http://lm-studio-host:1234   LM Studio direct
UPSTREAM_URL=http://localhost:4000
UPSTREAM_API_KEY=
UPSTREAM_MODEL=local

# --- Knowledge MCP server (embedded in the tool block sent to the upstream) ---
# Must be reachable from the upstream's network, not from Bailiff.
KNOWLEDGE_URL=http://localhost:8000/mcp
KNOWLEDGE_LABEL=knowledge
KNOWLEDGE_TOOL=search_archives

# --- Behaviour ---
BAILIFF_TIMEOUT=180
LOG_LEVEL=INFO
