# --- Transport ---
# stdio : default for direct agent integration (Copilot CLI, Claude Desktop)
# http  : streamable-http for remote/shared deployments
# sse   : legacy SSE (avoid for new clients)
BAILIFF_TRANSPORT=stdio
BAILIFF_HOST=0.0.0.0
BAILIFF_PORT=8100
BAILIFF_PATH=/mcp

# --- Upstream (any /v1/responses-compatible host with MCP tool support) ---
# Examples:
#   http://localhost:4000        LiteLLM proxy on the same host
#   http://lm-studio-host:1234   LM Studio direct
UPSTREAM_URL=http://localhost:4000
UPSTREAM_API_KEY=
UPSTREAM_MODEL=local

# --- Knowledge MCP server (embedded in the tool block sent to the upstream) ---
# Must be reachable from the upstream's network, not from Bailiff.
KNOWLEDGE_URL=http://localhost:8000/mcp
KNOWLEDGE_LABEL=knowledge

# Comma-separated list of Scribe tools the upstream model may call.
# Leave unset to allow the full Scribe v1 surface (recommended default):
#   search_archives,list_collections,recall,remember,forget,list_memories,
#   ingest_url,ingest_path,forget_collection
# Set to a narrower list to lock down what the model can do, e.g.:
#   KNOWLEDGE_ALLOWED_TOOLS=search_archives,recall
# KNOWLEDGE_ALLOWED_TOOLS=

# Back-compat single-tool override. If set, takes precedence over the list above.
# KNOWLEDGE_TOOL=search_archives

# --- System prompt sent to the upstream model on every request ---
# Loaded from this file inside the container. Mount your own at the same
# path via docker-compose to override without rebuilding the image.
BAILIFF_SYSTEM_PROMPT_FILE=/app/system_prompt.md
# Inline override; if set, takes precedence over the file.
# BAILIFF_INSTRUCTIONS=

# --- Behaviour ---
BAILIFF_TIMEOUT=180
LOG_LEVEL=INFO
