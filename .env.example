# --- Transport ---
# stdio  : default for direct agent integration (Copilot CLI, Claude Desktop)
# http   : streamable-http for remote/shared deployments
# sse    : legacy SSE (avoid for new clients)
BAILIFF_TRANSPORT=stdio
BAILIFF_HOST=0.0.0.0
BAILIFF_PORT=8100
BAILIFF_PATH=/mcp

# --- Catchpole gateway (the LiteLLM proxy upstream) ---
CATCHPOLE_URL=http://localhost:4000
CATCHPOLE_API_KEY=
CATCHPOLE_MODEL=lm_studio/local

# --- Scribe (referenced in the MCP tool block sent to LM Studio) ---
SCRIBE_URL=http://localhost:8000/mcp
SCRIBE_LABEL=scribe

# --- Behaviour ---
BAILIFF_TIMEOUT=180
LOG_LEVEL=INFO
